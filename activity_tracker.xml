<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ActivityTrackerActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Workout Videos"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="14sp"
            android:textColor="#9E9E9E" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/workout_categories"
            android:backgroundTint="#424242"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Difficulty Level"
            android:textSize="14sp"
            android:textColor="#9E9E9E" />

        <Spinner
            android:id="@+id/spinnerDifficulty"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/difficulty_levels"
            android:backgroundTint="#424242"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Duration"
            android:textSize="14sp"
            android:textColor="#9E9E9E" />

        <Spinner
            android:id="@+id/spinnerDuration"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/durations"
            android:backgroundTint="#424242"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnSearchWorkouts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SEARCH WORKOUTS"
            android:backgroundTint="#A35FB4"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="true"
            app:cornerRadius="4dp" />

        <TextView
            android:id="@+id/tvSearchingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Searching YouTube..."
            android:gravity="center"
            android:textColor="#9E9E9E"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp" />

        <!-- AI Tracking Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Activity Sensing"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/selectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <RadioGroup
                android:id="@+id/rgWorkoutType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">
                <RadioButton android:id="@+id/running" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Running" android:checked="true"/>
                <RadioButton android:id="@+id/gym" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Gym Workout"/>
                <RadioButton android:id="@+id/yoga" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Yoga"/>
            </RadioGroup>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/startBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Start AI Tracking"
            android:backgroundTint="#2196F3"
            app:cornerRadius="8dp" />

        <!-- Sensing Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sensingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#F5F5F5">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">
                <ProgressBar android:layout_width="48dp" android:layout_height="48dp" />
                <TextView android:id="@+id/tvStatusHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Sensing..." android:layout_marginTop="12dp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvSensorData" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BPM: --"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Report Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/reportCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Session Report" android:textStyle="bold" android:textSize="18sp"/>
                <TextView android:id="@+id/reportHeartRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- BPM" android:textColor="#E91E63" android:textSize="20sp" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/reportCalories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- kcal" android:textColor="#4CAF50" android:textSize="20sp"/>
                <TextView android:id="@+id/reportAiInsight" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center"/>
                <Button android:id="@+id/btnDone" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Finish" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
